pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK17'
    }

    stages {
        stage('Checkout Git') {
            steps {
                git 'https://github.com/MonishwaranD/maven-jenkins-ci-pipeline.git'
            }
        }

        stage('Build and Test') {
            steps {
                dir('simple-maven-app') {
                    bat 'mvn clean test'
                }
            }
        }
    }
}